}const $ = (id) => document.getElementById(id);

function clamp(n, min, max) {
  return Math.max(min, Math.min(max, n));
}

// Demo-only: fake “today” stats that change slightly on refresh.
function seedDemo() {
  const spent = Math.round(10 + Math.random() * 120);
  const budget = 75;
  const urge = Math.round(1 + Math.random() * 9);

  const triggers = ["Boredom", "Stress", "After a win", "Late-night scrolling", "Social pressure"];
  const topTrigger = triggers[Math.floor(Math.random() * triggers.length)];

  const streak = Math.round(1 + Math.random() * 9);

  $("spentToday").textContent = `$${spent}`;
  $("budgetToday").textContent = `$${budget}`;
  $("urgeLevel").textContent = `${urge}/10`;
  $("topTrigger").textContent = topTrigger;
  $("streak").textContent = `${streak} days`;

  // Simple risk score for the landing page demo:
  // spending weight + urge weight + "late night" trigger bump (proxy)
  let risk = (spent / budget) * 40 + (urge / 10) * 50;
  if (topTrigger.toLowerCase().includes("late")) risk += 12;

  risk = clamp(Math.round(risk), 5, 95);
  $("riskFill").style.width = `${risk}%`;

  const badge = $("riskBadge");
  badge.textContent = risk < 35 ? "LOW" : risk < 70 ? "MED" : "HIGH";

  // Badge colors (no CSS variables changed; just classes by inline style)
  if (risk < 35) {
    badge.style.color = "var(--good)";
    badge.style.background = "rgba(52,211,153,.12)";
  } else if (risk < 70) {
    badge.style.color = "var(--warn)";
    badge.style.background = "rgba(251,191,36,.12)";
  } else {
    badge.style.color = "var(--bad)";
    badge.style.background = "rgba(251,113,133,.12)";
  }
}

function setupInteractions() {
  const note = $("miniNote");
  const cooldownBtn = $("cooldownBtn");
  const checkinBtn = $("checkinBtn");

  let cooldownActive = false;
  let remaining = 0;
  let timer = null;

  cooldownBtn.addEventListener("click", () => {
    if (cooldownActive) return;

    cooldownActive = true;
    remaining = 10 * 60; // 10 minutes

    cooldownBtn.textContent = "Cooldown: 10:00";
    note.textContent = "Nice. Step away from betting apps. Try: water + 10 deep breaths.";

    timer = setInterval(() => {
      remaining -= 1;
      const m = String(Math.floor(remaining / 60)).padStart(2, "0");
      const s = String(remaining % 60).padStart(2, "0");
      cooldownBtn.textContent = `Cooldown: ${m}:${s}`;

      if (remaining <= 0) {
        clearInterval(timer);
        cooldownActive = false;
        cooldownBtn.textContent = "Start 10-min cooldown";
        note.textContent = "Cooldown complete. If you still feel the urge, try another reset or contact support.";
      }
    }, 1000);
  });

  checkinBtn.addEventListener("click", () => {
    note.textContent =
      "Check-in idea: Rate urge (1–10), pick a trigger, and log what happened. Then choose a safer alternative.";
  });

  const form = $("waitlistForm");
  const formNote = $("formNote");

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = $("email").value.trim();
    if (!email) return;

    // Demo-only: store locally (no backend)
    const saved = JSON.parse(localStorage.getItem("betmaster_waitlist") || "[]");
    if (!saved.includes(email)) saved.push(email);
    localStorage.setItem("betmaster_waitlist", JSON.stringify(saved));

    form.reset();
    formNote.textContent = "You're on the list ✅ We’ll email you when the beta opens.";
  });

  $("year").textContent = new Date().getFullYear();
}

seedDemo();
setupInteractions();
